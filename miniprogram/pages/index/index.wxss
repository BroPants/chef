.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
}

.header {
  text-align: center;
  margin-bottom: 80rpx;
}

.title {
  display: block;
  font-size: 44rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #888;
}

.actions {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
  width: 100%;
  max-width: 560rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  height: 120rpx;
  border-radius: 16rpx;
  font-size: 32rpx;
}

.action-btn.primary {
  background: linear-gradient(135deg, #1a5f2a 0%, #2d8a3e 100%);
  color: #fff;
}

.action-btn.secondary {
  background: #fff;
  color: #1a5f2a;
  border: 2rpx solid #1a5f2a;
}

.action-icon {
  font-size: 40rpx;
}

.loading-wrap {
  margin-top: 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid #e8e8e8;
  border-top-color: #1a5f2a;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #888;
}

.error-wrap {
  margin-top: 40rpx;
  padding: 32rpx;
  background: #fff2f0;
  border: 1rpx solid #ffccc7;
  border-radius: 12rpx;
  max-width: 560rpx;
}

.error-text {
  display: block;
  font-size: 28rpx;
  color: #cf1322;
  margin-bottom: 12rpx;
}

.error-tip {
  display: block;
  font-size: 24rpx;
  color: #888;
  margin-bottom: 24rpx;
  line-height: 1.5;
}

.error-actions {
  display: flex;
  justify-content: center;
}

.btn-retry {
  padding: 16rpx 48rpx;
  font-size: 28rpx;
  color: #1a5f2a;
  background: #fff;
  border: 1rpx solid #1a5f2a;
  border-radius: 8rpx;
}
