.container {
  padding-bottom: 60rpx;
}

.header {
  padding: 40rpx 0;
  border-bottom: 1rpx solid #eee;
}

.dish-name {
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
}

.section {
  margin-top: 40rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #1a5f2a;
  margin-bottom: 24rpx;
}

.ingredient-list {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx 32rpx;
}

.ingredient-item {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  font-size: 28rpx;
  color: #555;
}

.ingredient-dot {
  color: #1a5f2a;
  margin-right: 16rpx;
}

.ingredient-text {
  flex: 1;
}

.step-list {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx 32rpx;
}

.step-item {
  display: flex;
  gap: 24rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.step-item:last-child {
  border-bottom: none;
}

.step-num {
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  background: #1a5f2a;
  color: #fff;
  border-radius: 50%;
  font-size: 24rpx;
  flex-shrink: 0;
}

.step-text {
  flex: 1;
  font-size: 28rpx;
  color: #555;
  line-height: 1.6;
}

.empty,
.error {
  text-align: center;
  padding: 80rpx 0;
}

.empty-text,
.error-text {
  font-size: 28rpx;
  color: #888;
}

.error-text {
  color: #cf1322;
}

.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
  gap: 24rpx;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid #e8e8e8;
  border-top-color: #1a5f2a;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #888;
}
